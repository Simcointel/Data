{
  "cache": "public, max-age=300",
  "datasets": {
    "anomalies": {
      "description": "Z-score anomaly events",
      "items": "{ realm, category, zScore, deviation, direction, timestamp }",
      "type": "array"
    },
    "contagion": {
      "description": "Contagion risk assessments",
      "items": "{ realm, origin, spread, affected, risk }",
      "type": "array"
    },
    "correlations": {
      "description": "Cross-category correlation coefficients",
      "items": "{ realm, pair, coefficient, strength }",
      "type": "array"
    },
    "dashboard": {
      "description": "Latest dashboard summaries per realm",
      "pattern": "realm-{id}: { scores: { eh, ms, st, ip, sr }, regime: { na, sc }, alerts, sectors, generatedAt }",
      "type": "object"
    },
    "divergence": {
      "description": "Sector divergence signals",
      "items": "{ realm, sector, strength, type, signal }",
      "type": "array"
    },
    "history": {
      "description": "Macro history entries array",
      "items": "{ date, companiesValue, activeCompanies, bondsSold, totalBuildings }",
      "type": "array"
    },
    "indexes": {
      "description": "Price indexes array",
      "items": "{ date, cpi, coreCpi, gdp }",
      "type": "array"
    },
    "inflation": {
      "description": "Inflation rates array",
      "items": "{ date, cpiRate, coreCpiRate, gdpGrowth }",
      "type": "array"
    },
    "macro": {
      "description": "Latest macro snapshot for a realm",
      "fields": {
        "generatedAt": "ISO timestamp",
        "latest": "{ companiesValue, activeCompanies, bondsSold, totalBuildings }",
        "latestIndexes": "{ cpi, coreCpi, gdp } | null",
        "latestInflation": "{ cpiRate, coreCpiRate, gdpGrowth } | null",
        "realm": "string"
      },
      "type": "object"
    },
    "sectors": {
      "description": "Sector intelligence per realm",
      "pattern": "realm-{id}: [{ sector, strength, momentum, leader, volatility }]",
      "type": "object"
    }
  },
  "description": "SimcoIntel public dataset schema",
  "exportFormats": [
    "json",
    "csv"
  ],
  "rateLimit": "120 requests/minute/IP",
  "version": "1.0"
}
